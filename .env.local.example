# Copy to .env.local (Next.js loads .env.local automatically — this file is NOT loaded).
#
# MySQL 8.x / AWS RDS: use the RDS endpoint as DB_HOST, DB_PORT=3306 (or your port),
# and enable TLS for most public connections:
#   DB_SSL=true
# Optional: path to AWS RDS combined CA bundle (.pem) for certificate verification
#   DB_SSL_CA=C:\path\to\global-bundle.pem
# On Amplify/serverless, use PEM contents instead (no file path):
#   DB_SSL_CA_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# If you omit DB_SSL_CA, connections still encrypt when DB_SSL=true but skip CA verification
# (set DB_SSL_REJECT_UNAUTHORIZED=false explicitly only if you need that behavior).
#
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_user
DB_PASS=your_password
DB_NAME=your_database

# Optional: max simultaneous connections per Node process (default 5, max 25).
# Keep this small vs RDS max_connections. If you see ER_CON_COUNT_ERROR, lower this or raise RDS max_connections.
# DB_POOL_LIMIT=5

# Optional: session idle timeout in minutes (default 10)
# SESSION_IDLE_MINUTES=10
